NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=telco12345

# LLM provider for the GraphRAG explanation step.
# "mock" (default) needs no API key and runs fully offline.
# Set to "anthropic", "openai" or "groq" and provide the matching API key to use a real LLM.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
